# Generated by cloudops-sonic-migrator skill
# Only needed if NOT using Sonic Pipeline.
# Placeholders: {{SERVICE_NAME}}, {{DOCKER_NAME}}, {{DOCKER_PATH}}, {{VAULT_ROLE}},
#   {{SECRET_PATH}}, {{NAMESPACE}}, {{ENVIRONMENT_QA}}
name: build-pr

on:
  pull_request:
  workflow_dispatch:

jobs:
  helmfile-lint:
    uses: github-actions/pipelines/.github/workflows/run-helmfile.yml@v1
    with:
      helmfile-commands: lint
      helmfile-args: --state-values-set image_name={{DOCKER_NAME}} --state-values-set app_version=pr-${{ github.event.pull_request.number }}
      environment: {{ENVIRONMENT_QA}}
      namespace: {{NAMESPACE}}

  docker-build:
    name: Build and push image
    uses: github-actions/pipelines-docker/.github/workflows/publish-docker-artifactory.yml@v1
    permissions:
      contents: read
      id-token: write
    with:
      version: pr-${{ github.event.pull_request.number }}
      docker-name: {{DOCKER_NAME}}/prs
      docker-path: {{DOCKER_PATH_DEV}}
      vault-role: "{{VAULT_ROLE}}"
      secret-path: "{{SECRET_PATH}}"
    secrets: inherit
