# Generated by cloudops-sonic-migrator skill
# Only needed if NOT using Sonic Pipeline (Sonic Pipeline handles CI/CD automatically).
# Placeholders: {{SERVICE_NAME}}, {{DOCKER_NAME}}, {{DOCKER_PATH}}, {{VAULT_ROLE}},
#   {{SECRET_PATH}}, {{TEAM_NAME}}, {{NAMESPACE}}, {{SLACK_STAGE}}, {{SLACK_PROD}},
#   {{VERSION_PREFIX}}, {{ENVIRONMENT_QA}}, {{ENVIRONMENT_STG}}, {{ENVIRONMENT_PRD}}
name: build-deploy-main

on:
  push:
    branches:
      - main
  workflow_dispatch:

jobs:
  generate-version:
    runs-on: [self-hosted, docker-runner]
    outputs:
      version-number: ${{ steps.generate-version.outputs.version-number }}
    steps:
      - name: Checkout code
        uses: actions/checkout@v4
        with:
          fetch-depth: 0
          show-progress: false
      - name: Generate version
        id: generate-version
        uses: github-actions/generate-version@v1
        with:
          prefix: '{{VERSION_PREFIX}}'

  docker-build:
    name: "Build and push image"
    needs: [generate-version]
    uses: github-actions/pipelines-docker/.github/workflows/publish-docker-artifactory.yml@v1
    permissions:
      contents: read
      id-token: write
    with:
      version: ${{ needs.generate-version.outputs.version-number }}
      docker-name: {{DOCKER_NAME}}
      docker-path: {{DOCKER_PATH}}
      vault-role: "{{VAULT_ROLE}}"
      secret-path: "{{SECRET_PATH}}"
    secrets: inherit

  create-tag:
    name: "Create tag"
    needs: [generate-version, docker-build]
    uses: github-actions/pipelines/.github/workflows/publish-version.yml@v1
    with:
      version-number: ${{ needs.generate-version.outputs.version-number }}

  deploy-qa:
    uses: github-actions/pipelines/.github/workflows/deploy-helmfile.yml@v1
    needs: [generate-version, docker-build]
    strategy:
      matrix:
        env_name:
          - {{ENVIRONMENT_QA}}
    permissions:
      contents: read
      pull-requests: read
      id-token: write
    with:
      app: {{SERVICE_NAME}}
      environment: ${{ matrix.env_name }}
      image-tag: ${{ needs.generate-version.outputs.version-number }}
      image-name: {{DOCKER_NAME}}
      team-name: {{TEAM_NAME}}
      namespace: {{NAMESPACE}}
      docker-repository: {{DOCKER_PATH}}
      slack-channel-id-for-stage: {{SLACK_STAGE}}
      extra-helmfile-args: --state-values-set app_version="${{ needs.generate-version.outputs.version-number }}"
      wait-for-rollout: true
    secrets: inherit

  deploy-staging:
    uses: github-actions/pipelines/.github/workflows/deploy-helmfile.yml@v1
    needs: [generate-version, docker-build, deploy-qa]
    strategy:
      matrix:
        env_name:
          - {{ENVIRONMENT_STG}}
    permissions:
      contents: read
      pull-requests: read
      id-token: write
    with:
      app: {{SERVICE_NAME}}
      environment: ${{ matrix.env_name }}
      image-tag: ${{ needs.generate-version.outputs.version-number }}
      image-name: {{DOCKER_NAME}}
      team-name: {{TEAM_NAME}}
      namespace: {{NAMESPACE}}
      docker-repository: {{DOCKER_PATH}}
      slack-channel-id-for-stage: {{SLACK_STAGE}}
      extra-helmfile-args: --state-values-set app_version="${{ needs.generate-version.outputs.version-number }}"
      wait-for-rollout: true
    secrets: inherit

  deploy-production:
    uses: github-actions/pipelines/.github/workflows/deploy-helmfile.yml@v1
    needs: [generate-version, docker-build, deploy-staging]
    strategy:
      matrix:
        env_name:
          - {{ENVIRONMENT_PRD}}
    permissions:
      contents: read
      pull-requests: read
      id-token: write
    with:
      app: {{SERVICE_NAME}}
      environment: ${{ matrix.env_name }}
      image-tag: ${{ needs.generate-version.outputs.version-number }}
      image-name: {{DOCKER_NAME}}
      team-name: {{TEAM_NAME}}
      namespace: {{NAMESPACE}}
      docker-repository: {{DOCKER_PATH}}
      slack-channel-id-for-prod: {{SLACK_PROD}}
      extra-helmfile-args: --state-values-set app_version="${{ needs.generate-version.outputs.version-number }}"
      wait-for-rollout: true
    secrets: inherit
