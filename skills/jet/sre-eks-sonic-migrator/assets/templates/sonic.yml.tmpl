# .sonic/sonic.yml — Sonic Pipeline Workload Spec
# Generated by sre-eks-sonic-migrator skill
#
# IMPORTANT: The `sonic-pipeline` skill is the authoritative source for the sonic.yml schema,
# field reference, and runtime-specific workload configuration. Load it for the latest apiVersion
# values, supported fields, and runtime-specific test configuration examples.
#
# Placeholders use {{PLACEHOLDER}} syntax. Replace ALL before committing.

# --- Root Spec Version ---
# Format: justeattakeaway.com/sonic-spec/<major>.<minor>.<patch>
# Fetch latest available version from Backstage: search "sonic spec reference"
apiVersion: justeattakeaway.com/sonic-spec/{{SONIC_SPEC_VERSION}}

# --- Metadata ---
metadata:
  metadataId: {{APP_NAME}}
  project: {{PROJECT_ID}}
  team: {{TEAM_NAME}}
  vaultRole: {{VAULT_ROLE}}             # = PROJECT_ID (Vault role in OneEKS = project name)
  vaultSecretPath: {{VAULT_SECRET_PATH}} # Legacy: "secret/{APP_NAME}", OneSecrets: "{PROJECT_ID}/data/{APP_NAME}"
  # Optional: deploy notifications per environment
  # deployNotifications:
  #   default: "#deploy-notifications"
  #   prd: "#deploy-notifications-prd"

# --- Environments ---
# Cluster identifiers follow: <region>-<platform>-<stage>-<number>
# Fetch valid identifiers from Backstage: search "sonic environments and accounts"
environments:
  qa:
    - {{QA_CLUSTER}}          # e.g., euw1-pdv-qa-2
  stg:
    - {{STG_CLUSTER}}         # e.g., euw1-pdv-stg-2
  prd:
    - {{PRD_CLUSTER}}         # e.g., euw1-pdv-prd-2

# --- Workloads ---
workloads:
  # Workloads have their own independent apiVersion
  apiVersion: justeattakeaway.com/workloads/{{WORKLOADS_VERSION}}

  # --- Resources ---
  # Defines how the workload runs. Keys must match across resources, artifacts, and deployment.
  resources:
    {{APP_NAME}}:
      type: service
      # deploymentMethod: helmfile | argocd  (default: helmfile)
      # For ArgoCD deployments, uncomment and configure:
      # deploymentMethod: argocd
      # autoSync: true
      # featureBranches: false
      spec:
        runtimeType: k8s      # k8s (default) or ecs

      # --- ArgoCD-only fields (uncomment if deploymentMethod: argocd) ---
      # spec:
      #   runtimeType: k8s
      #   resources:
      #     requests:
      #       cpu: {{CPU_REQUEST}}
      #       memory: {{MEMORY_REQUEST}}
      #     limits:
      #       cpu: {{CPU_LIMIT}}
      #       memory: {{MEMORY_LIMIT}}
      #   ports:
      #     http:
      #       name: http
      #       port: {{CONTAINER_PORT}}
      #   replicas: {{REPLICAS}}
      #   helmOverrides:
      #     deployment:
      #       enableDatadog: true

  # --- Artifacts ---
  # Defines how the workload is built.
  # appType: api | worker
  # runtime: dotnet | go | java-gradle | java-maven | python | redpandaconnector
  # runtimeVersion: integer major version (e.g., 9 for .NET 9, 21 for Java 21)
  artifacts:
    {{APP_NAME}}:
      appType: {{APP_TYPE}}
      runtime: {{RUNTIME}}
      runtimeVersion: {{RUNTIME_VERSION}}
      # architecture: amd64    # amd64 (default) or arm64

      # --- Build-time tests (optional) ---
      # Tests run during CI build phase, before deployment.
      # Supported types: unit, integration
      # tests:
      #   - type: unit
{{ARTIFACT_TESTS}}

  # --- Deployment tests (optional) ---
  # Tests run after deployment to validate the live service.
  # Supported types: e2e, acceptance
  # deployment:
  #   {{APP_NAME}}:
  #     tests:
  #       - type: e2e
  #         skipEnvironments:
  #           - {{PRD_CLUSTER}}
{{DEPLOYMENT_TESTS}}

